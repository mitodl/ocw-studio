{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["local>mitodl/.github:renovate-config"],
  "packageRules": [
    {
      "matchManagers": ["custom.regex"],
      "matchFileNames": [
        "docker/ocw-course-publisher/Dockerfile",
        "main/templates/base.html"
      ],
      "automerge": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^docker/ocw-course-publisher/Dockerfile$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+?) depName=(?<depName>.+?)(?: packageName=(?<packageName>.+?))?(?: registryUrl=(?<registryUrl>.+?))?(?: versioning=(?<versioning>[a-z-]+?))?\\s*.+\\s*=\\s*\"(?<currentValue>.+?)\""
      ]
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^main/templates/base\\.html$/"],
      "matchStrings": [
        "cdn\\.jsdelivr\\.net/npm/mathjax@(?<currentValue>[^/]+)/tex-svg\\.js"
      ],
      "datasourceTemplate": "npm",
      "depNameTemplate": "mathjax"
    }
  ]
}
